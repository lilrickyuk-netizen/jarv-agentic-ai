# JARV Agentic AI System - Production Environment Configuration
# This file shows required configuration for production deployment
# Copy relevant values to your production .env file

# ==============================================
# CRITICAL SECURITY - MUST CHANGE
# ==============================================
SECRET_KEY=CHANGE_THIS_USE_openssl_rand_hex_32
JWT_SECRET_KEY=CHANGE_THIS_USE_openssl_rand_hex_32
RUNNER_TOKEN=CHANGE_THIS_USE_openssl_rand_hex_32

# ==============================================
# DATABASE - PRODUCTION
# ==============================================
POSTGRES_USER=jarv_prod
POSTGRES_PASSWORD=STRONG_RANDOM_PASSWORD_HERE
POSTGRES_DB=jarv_prod
POSTGRES_HOST=your-postgres-host.com
POSTGRES_PORT=5432
DATABASE_URL=postgresql://jarv_prod:STRONG_PASSWORD@your-postgres-host.com:5432/jarv_prod

# Connection Pooling
DATABASE_POOL_SIZE=50

# ==============================================
# REDIS - PRODUCTION
# ==============================================
REDIS_URL=redis://your-redis-host.com:6379/0
REDIS_MAX_CONNECTIONS=100

# ==============================================
# APPLICATION - PRODUCTION
# ==============================================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=WARNING
ALLOWED_ORIGINS=https://your-domain.com,https://api.your-domain.com

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ==============================================
# LLM PROVIDERS - REQUIRED
# ==============================================
CLAUDE_API_KEY=your_production_claude_api_key

# Optional providers
OPENAI_API_KEY=your_production_openai_api_key
GEMINI_API_KEY=your_production_gemini_api_key

# ==============================================
# FRONTEND - PRODUCTION
# ==============================================
NEXT_PUBLIC_API_URL=https://api.your-domain.com
NEXT_PUBLIC_WS_URL=wss://api.your-domain.com/ws
NODE_ENV=production

# ==============================================
# SECURITY - PRODUCTION
# ==============================================
CORS_ENABLED=true
RATE_LIMITING_ENABLED=true
RATE_LIMIT_PER_MINUTE=30
SESSION_TIMEOUT_MINUTES=30

# ==============================================
# AUTHORITY - PRODUCTION
# ==============================================
DEFAULT_AUTHORITY_LEVEL=2
AUTO_STAGING_DEPLOY=true
AUTO_PRODUCTION_REPAIR=false

# ==============================================
# MONITORING - PRODUCTION
# ==============================================
AUDIT_LOGGING_ENABLED=true
BOUNDARY_REPORTING_ENABLED=true
LOG_RETENTION_DAYS=90

# Sentry for error tracking
SENTRY_DSN=your_sentry_dsn_here

# ==============================================
# CELERY - PRODUCTION
# ==============================================
CELERY_BROKER_URL=redis://your-redis-host.com:6379/0
CELERY_RESULT_BACKEND=redis://your-redis-host.com:6379/0
CELERY_WORKER_CONCURRENCY=8

# ==============================================
# SWARM - PRODUCTION
# ==============================================
SWARM_ENABLED=true
MAX_SUBAGENTS_PER_WORKSPACE=20
MAX_SUBAGENTS_GLOBAL=100
SUBAGENT_TIMEOUT=7200

# ==============================================
# SELF-EVOLUTION - PRODUCTION
# ==============================================
SELF_EVOLUTION_ENABLED=true
AUTO_APPROVE_SAFE_EVOLUTION=false

# ==============================================
# SELF-HEALING - PRODUCTION
# ==============================================
SELF_HEALING_ENABLED=true

# ==============================================
# BACKUP - PRODUCTION
# ==============================================
AUTO_BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# ==============================================
# EMAIL - PRODUCTION
# ==============================================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_api_key
SMTP_FROM=noreply@your-domain.com

# ==============================================
# EXTERNAL SERVICES - PRODUCTION
# ==============================================
GITHUB_TOKEN=your_production_github_token
UNSPLASH_ACCESS_KEY=your_unsplash_key
PEXELS_API_KEY=your_pexels_key

# ==============================================
# CLOUD CONFIGURATION
# ==============================================
CLOUD_MODE=true
CLOUD_REGION=us-east-1

# ==============================================
# PERFORMANCE - PRODUCTION
# ==============================================
HOT_RELOAD=false
DEBUG_TOOLBAR=false
SEED_TEST_DATA=false
EXPERIMENTAL_FEATURES=false

# ==============================================
# SSL/TLS
# ==============================================
# Configure SSL certificates in your reverse proxy (nginx/caddy)
# or use a service like Cloudflare

# ==============================================
# DEPLOYMENT NOTES
# ==============================================
# 1. Generate strong random keys for SECRET_KEY, JWT_SECRET_KEY, and RUNNER_TOKEN
# 2. Use managed PostgreSQL service (AWS RDS, DigitalOcean, etc.)
# 3. Use managed Redis service (AWS ElastiCache, Redis Cloud, etc.)
# 4. Set up proper SSL/TLS certificates
# 5. Configure firewall rules to restrict access
# 6. Set up monitoring and alerting
# 7. Configure automated backups
# 8. Use environment-specific secrets management
# 9. Rotate credentials regularly
# 10. Review security settings before launch
