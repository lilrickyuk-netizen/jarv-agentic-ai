# JARV Agentic AI System - Environment Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env file to version control

# ==============================================
# DATABASE CONFIGURATION
# ==============================================
POSTGRES_USER=jarv
POSTGRES_PASSWORD=change_this_secure_password
POSTGRES_DB=jarv
DATABASE_URL=postgresql://jarv:change_this_secure_password@localhost:5432/jarv

# ==============================================
# REDIS CONFIGURATION
# ==============================================
REDIS_URL=redis://localhost:6379/0

# ==============================================
# CELERY CONFIGURATION
# ==============================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ==============================================
# BACKEND CONFIGURATION
# ==============================================
SECRET_KEY=change_this_to_random_secret_key_use_openssl_rand_hex_32
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Backend API
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# JWT Configuration
JWT_SECRET_KEY=change_this_to_random_jwt_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==============================================
# LLM PROVIDER API KEYS
# ==============================================
# Claude API (Primary - Required)
CLAUDE_API_KEY=your_claude_api_key_here

# OpenAI API (Optional)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API (Optional)
GEMINI_API_KEY=your_gemini_api_key_here

# Ollama/Local Models (Optional)
OLLAMA_BASE_URL=http://localhost:11434

# ==============================================
# FRONTEND CONFIGURATION
# ==============================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NODE_ENV=development

# ==============================================
# LOCAL RUNNER CONFIGURATION
# ==============================================
LOCAL_RUNNER_PORT=8001
RUNNER_TOKEN=change_this_secure_runner_token

# Approved folders for local runner (comma-separated)
APPROVED_FOLDERS=/path/to/projects,/path/to/workspaces

# Banned folders (comma-separated)
BANNED_FOLDERS=/path/to/banking,/path/to/crypto,/path/to/passwords

# ==============================================
# CLOUD RUNNER CONFIGURATION
# ==============================================
CLOUD_MODE=false
CLOUD_REGION=us-east-1

# ==============================================
# AUTHORITY CONFIGURATION
# ==============================================
# Default authority level for operations (1-7)
DEFAULT_AUTHORITY_LEVEL=3

# Enable automatic staging deployments
AUTO_STAGING_DEPLOY=false

# Enable automatic production repairs (Level 6 actions)
AUTO_PRODUCTION_REPAIR=false

# ==============================================
# SWARM CONFIGURATION
# ==============================================
# Maximum number of sub-agents per workspace
MAX_SUBAGENTS_PER_WORKSPACE=10

# Maximum total sub-agents globally
MAX_SUBAGENTS_GLOBAL=50

# Sub-agent timeout (seconds)
SUBAGENT_TIMEOUT=3600

# ==============================================
# SELF-EVOLUTION CONFIGURATION
# ==============================================
# Enable self-evolution system
SELF_EVOLUTION_ENABLED=true

# Auto-approve safe self-evolution changes
AUTO_APPROVE_SAFE_EVOLUTION=false

# ==============================================
# MONITORING AND LOGGING
# ==============================================
# Enable audit logging
AUDIT_LOGGING_ENABLED=true

# Enable boundary reporting
BOUNDARY_REPORTING_ENABLED=true

# Log retention days
LOG_RETENTION_DAYS=90

# ==============================================
# VOICE COMMAND CONFIGURATION
# ==============================================
# Enable voice commands
VOICE_ENABLED=false

# Speech-to-text provider (whisper, google, azure)
STT_PROVIDER=whisper

# Text-to-speech provider (elevenlabs, google, azure)
TTS_PROVIDER=elevenlabs

# Voice API keys (if using cloud providers)
ELEVENLABS_API_KEY=your_elevenlabs_api_key
GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key
AZURE_SPEECH_KEY=your_azure_speech_key

# ==============================================
# EXTERNAL SERVICES (Optional)
# ==============================================
# Email service (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=jarv@yourcompany.com

# Sentry (Error tracking)
SENTRY_DSN=your_sentry_dsn_here

# GitHub (for repository operations)
GITHUB_TOKEN=your_github_token_here

# ==============================================
# ASSET SOURCES (Optional)
# ==============================================
# API keys for asset sources
UNSPLASH_ACCESS_KEY=your_unsplash_access_key
PEXELS_API_KEY=your_pexels_api_key

# ==============================================
# BACKUP CONFIGURATION
# ==============================================
# Enable automated backups
AUTO_BACKUP_ENABLED=true

# Backup schedule (cron format)
BACKUP_SCHEDULE=0 2 * * *

# Backup retention days
BACKUP_RETENTION_DAYS=30

# ==============================================
# SECURITY
# ==============================================
# Enable rate limiting
RATE_LIMITING_ENABLED=true

# Rate limit (requests per minute)
RATE_LIMIT_PER_MINUTE=60

# Enable CORS
CORS_ENABLED=true

# Session timeout (minutes)
SESSION_TIMEOUT_MINUTES=60

# ==============================================
# FEATURE FLAGS
# ==============================================
# Enable experimental features
EXPERIMENTAL_FEATURES=false

# Enable swarm system
SWARM_ENABLED=true

# Enable company operator
COMPANY_OPERATOR_ENABLED=true

# Enable self-healing
SELF_HEALING_ENABLED=true

# ==============================================
# PERFORMANCE
# ==============================================
# Worker concurrency
CELERY_WORKER_CONCURRENCY=4

# Max connections to database
DATABASE_POOL_SIZE=20

# Redis max connections
REDIS_MAX_CONNECTIONS=50

# ==============================================
# DEVELOPMENT ONLY
# ==============================================
# Enable hot reload
HOT_RELOAD=true

# Enable debug toolbar
DEBUG_TOOLBAR=false

# Seed database with test data
SEED_TEST_DATA=false
