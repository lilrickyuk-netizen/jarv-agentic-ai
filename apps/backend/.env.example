# JARV Backend - Environment Configuration Example
# Copy this file to .env and update with your values

# Application
PROJECT_NAME="JARV Agentic AI System"
VERSION="1.0.0"
ENVIRONMENT=development  # development, staging, production
DEBUG=false
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
HOT_RELOAD=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Database
POSTGRES_USER=jarv
POSTGRES_PASSWORD=jarv_password
POSTGRES_DB=jarv
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://jarv:jarv_password@localhost:5432/jarv
DATABASE_POOL_SIZE=20

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# Security (REQUIRED - Generate strong keys for production!)
SECRET_KEY=your-secret-key-min-32-characters-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
SESSION_TIMEOUT_MINUTES=60

# CORS
CORS_ENABLED=true

# AI Provider API Keys (will be used in Phase 4)
CLAUDE_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Feature Flags
SWARM_ENABLED=true
SELF_EVOLUTION_ENABLED=true
COMPANY_OPERATOR_ENABLED=true
SELF_HEALING_ENABLED=true
VOICE_ENABLED=false

# Authority and Limits
DEFAULT_AUTHORITY_LEVEL=3
MAX_SUBAGENTS_PER_WORKSPACE=50
MAX_SUBAGENTS_GLOBAL=500
SUBAGENT_SPAWN_COOLDOWN_SECONDS=1

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# Monitoring
SENTRY_DSN=
ENABLE_METRICS=false
